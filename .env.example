# Copy to .env.local and fill in real values (gitignored).

# Postgres — FM's local docker Postgres on host port 5432.
# Format must be plain postgresql:// (no +asyncpg).
DATABASE_URL=postgresql://flowmanner:CHANGE_ME@localhost:5432/flowmanner

# GitHub — used in phase 4 (PR sync).
GH_TOKEN=
GH_REPO=glennguilloux/flowmanner

# FlowManner backend — used in phase 3 (inbox write-back).
# Auth question open: service token vs docker exec helper. Leave blank until decided.
FM_API_URL=
FM_SERVICE_TOKEN=

# Path to the FlowManner backend repo (used by session-ritual + kanban panels).
FM_REPO_PATH=/opt/flowmanner

# Relative path to the kanban board JSON inside FM_REPO_PATH.
KANBAN_BOARD_PATH=.hermes/kanban/board.json

# Hermes Agent — self-hosted AI agent framework (Nous Research).
# Used by the Hermes dashboard panel to show sessions, jobs, skills, and tools.
HERMES_URL=http://localhost:8642
HERMES_API_KEY=

# OpenCode — terminal-based AI coding assistant (anomalyco).
# Path to OpenCode's storage directory. Default: ~/.local/share/opencode
OPENCODE_STORAGE_PATH=

# Auth — shared secret for API routes. Leave blank for dev mode (no auth).
# Client components read NEXT_PUBLIC_ version to send in fetch() headers.
HIL_AUTH_SECRET=
NEXT_PUBLIC_HIL_AUTH_SECRET=